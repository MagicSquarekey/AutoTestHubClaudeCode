# AutoTest Hub 配置文件示例 / AutoTest Hub config example
# 复制此文件为 .env 并填入实际配置 / Copy this file to .env and fill in actual values

# 基础配置 / Basic settings
APP_NAME=AutoTest Hub
APP_VERSION=1.0.0
DEBUG=true

# 服务器配置 / Server settings
HOST=127.0.0.1
PORT=8686

# 安全配置（首次运行自动生成，无需手动配置）/ Security (auto-generated on first run)
SECRET_KEY=
ENCRYPTION_KEY=

# 执行引擎配置 / Execution engine settings
DEFAULT_TIMEOUT=30
DEFAULT_RETRY_COUNT=3
MAX_PARALLEL_TASKS=5
ENABLE_SCREENSHOT=true
ENABLE_VIDEO=false

# Web 驱动配置 / Web driver settings
BROWSER_TYPE=chromium
HEADLESS=false
BROWSER_TIMEOUT=30000

# Android 驱动配置 / Android driver settings
APPIUM_SERVER=http://127.0.0.1:4723
ADB_PATH=

# iOS 驱动配置 / iOS driver settings
WDA_BUNDLE_ID=
TIDEVICE_PATH=

# AI 配置（可选）/ AI settings (optional)
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-3.5-turbo

# 消息通知配置（可选）/ Notification settings (optional)
FEISHU_WEBHOOK=
WECOM_WEBHOOK=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SENDER=
EMAIL_PASSWORD=
