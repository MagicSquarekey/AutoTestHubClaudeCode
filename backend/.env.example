# AutoTest Hub 配置文件示例
# 复制此文件为 .env 并填入实际配置

# 基础配置
APP_NAME=AutoTest Hub
APP_VERSION=1.0.0
DEBUG=true

# 服务器配置
HOST=127.0.0.1
PORT=8686

# 安全配置（首次运行自动生成，无需手动配置）
SECRET_KEY=
ENCRYPTION_KEY=

# 执行引擎配置
DEFAULT_TIMEOUT=30
DEFAULT_RETRY_COUNT=3
MAX_PARALLEL_TASKS=5
ENABLE_SCREENSHOT=true
ENABLE_VIDEO=false

# Web驱动配置
BROWSER_TYPE=chromium
HEADLESS=false
BROWSER_TIMEOUT=30000

# Android驱动配置
APPIUM_SERVER=http://127.0.0.1:4723
ADB_PATH=

# iOS驱动配置
WDA_BUNDLE_ID=
TIDEVICE_PATH=

# AI配置（可选）
AI_API_KEY=
AI_API_URL=
AI_MODEL=gpt-3.5-turbo

# 消息通知配置（可选）
FEISHU_WEBHOOK=
WECOM_WEBHOOK=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=465
EMAIL_SENDER=
EMAIL_PASSWORD=
