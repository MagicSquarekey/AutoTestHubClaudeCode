{
  "name": "autotest-hub",
  "version": "1.0.0",
  "description": "AutoTest Hub - 自动化测试工具",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@vue/shared": "^3.5.38",
    "axios": "^1.6.2",
    "echarts": "^5.4.3",
    "element-plus": "^2.4.4",
    "pinia": "^2.1.7",
    "vue": "^3.3.11",
    "vue-codemirror": "^6.1.1",
    "vue-router": "^4.2.5",
    "vuedraggable": "^4.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^8.2.2",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "sass": "^1.69.5",
    "vite": "^8.0.16",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.autotest.hub",
    "productName": "AutoTest Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
